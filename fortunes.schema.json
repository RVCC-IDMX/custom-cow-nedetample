{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Song Lyrics",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["text"],
    "properties": {
      "text": {
        "type": "string",
        "description": "The song lyrics"
      },
      "song": {
        "type": "string",
        "description": "The song title"
      },
      "author": {
        "type": "string",
        "description": "Who sang this"
      }
    },
    "additionalProperties": false
  }
}